# =====================================================
# PastureFrame Plans Automation - Env Template
# =====================================================
# Copy to .env and fill in values. NEVER commit .env.

# --- App ---
APP_NAME="PastureFrame Plans Automation"
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Automation Safety ---
AUTOMATION_ENABLED=false
REQUIRE_HUMAN_APPROVAL=true
ALLOW_AUTO_PUBLISH=false
ALLOW_AUTO_PRICE_CHANGES=false
ALLOW_AUTO_CUSTOMER_MESSAGES=false

# --- Etsy Open API v3 ---
ETSY_API_BASE_URL=https://api.etsy.com/v3/application
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=
ETSY_CLIENT_ID=
ETSY_USER_ID=
ETSY_SHOP_ID=
ETSY_REDIRECT_URI=http://localhost:3000/api/etsy/callback
ETSY_SCOPES="listings_r listings_w shops_r shops_w transactions_r"
# OAuth2 tokens (populated by oauth flow; rotate via refresh)
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_TOKEN_EXPIRES_AT=
ETSY_OAUTH_STATE_SECRET=
ETSY_CODE_VERIFIER_SECRET=

# --- Database (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest

# --- File Storage ---
GOOGLE_DRIVE_ROOT_FOLDER_ID=
DROPBOX_ACCESS_TOKEN=

# --- Notifications ---
NOTIFY_EMAIL=ashton@example.com
SLACK_WEBHOOK_URL=

# --- Security ---
BUYER_ID_HASH_SALT=
EMERGENCY_STOP=false
LOG_LEVEL=info

# --- Server ---
PORT=3000
NODE_ENV=development
